{
  "includes": [
    "**/*.php"
  ],
  "excludes": [
    "**/vendor/**",
    "**/var/**"
  ],
  "plugins": [
    "https://plugins.dprint.dev/mago-0.20.0.wasm"
  ],
  "mago": {
    "phpVersionMajor": 8,
    "phpVersionMinor": 4,
    "printWidth": 120,
    "tabWidth": 4,
    "useTabs": false,
    "endOfLine": "lf",
    "singleQuote": true,
    "trailingComma": true,
    "removeTrailingCloseTag": true,
    "nullTypeHint": "null-pipe",
    "controlBraceStyle": "same-line",
    "closureBraceStyle": "same-line",
    "functionBraceStyle": "next-line",
    "methodBraceStyle": "next-line",
    "classlikeBraceStyle": "next-line",
    "inlineEmptyControlBraces": false,
    "inlineEmptyClosureBraces": true,
    "inlineEmptyFunctionBraces": true,
    "inlineEmptyMethodBraces": true,
    "inlineEmptyConstructorBraces": true,
    "inlineEmptyClasslikeBraces": true,
    "inlineEmptyAnonymousClassBraces": true,
    "methodChainBreakingStyle": "next-line",
    "firstMethodChainOnNewLine": true,
    "lineBeforeBinaryOperator": true,
    "alignAssignmentLike": true,
    "arrayTableStyleAlignment": true,
    "expandUseGroups": false,
    "sortUses": true,
    "separateUseTypes": true,
    "parenthesesInNewExpression": true,
    "parenthesesInAttribute": false,
    "parenthesesInExitAndDie": true,
    "parenthesesAroundNewInMemberAccess": false,
    "spaceAfterCastUnaryPrefixOperators": true,
    "spaceAfterLogicalNotUnaryPrefixOperator": true,
    "spaceAroundConcatenationBinaryOperator": true,
    "spaceAroundAssignmentInDeclare": true,
    "spaceBeforeArrowFunctionParameterListParenthesis": false,
    "spaceBeforeClosureParameterListParenthesis": false,
    "spaceBeforeClosureUseClauseParenthesis": true,
    "spaceWithinGroupingParenthesis": true,
    "emptyLineAfterNamespace": true,
    "emptyLineAfterOpeningTag": true,
    "emptyLineAfterDeclare": true,
    "emptyLineAfterUse": true,
    "emptyLineBeforeReturn": false,
    "separateClassLikeMembers": false,
    "emptyLineAfterMethod": false,
    "emptyLineAfterProperty": false,
    "emptyLineAfterClassLikeConstant": false,
    "emptyLineBetweenSameSymbols": false,
    "emptyLineAfterControlStructure": false
  }
}
