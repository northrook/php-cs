{
  "name": "northrook/php-cs",
  "type": "library",
  "description": "Custom PHP Coding Standards for Northrook projects.",
  "license": "BSD-3-Clause",
  "keywords": [
    "dev"
  ],
  "authors": [
    {
      "name": "Martin",
      "email": "mn@northrook.com"
    }
  ],
  "autoload": {
    "psr-4": {
      "Northrook\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests"
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "bin": [
    "bin/php-cs-config.php",
    "bin/collision-check.php"
  ],
  "require": {
    "php": ">=8.4",
    "phpstan/phpstan": "^2.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^13.2"
  },
  "scripts": {
    "php-cs-config": "php-cs-config.php",
    "collision": "collision-check.php",
    "phpstan": "vendor/bin/phpstan analyse",
    "test": "vendor/bin/phpunit",
    "fmt": "dprint fmt",
    "check": [
      "@phpstan",
      "@test",
      "@collision"
    ]
  }
}
